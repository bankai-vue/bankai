{
  // Aggregate config for the native TS 7.0 compiler (`tsgo`) — fast type-checking
  // for the SFC-free packages (SPEC.md §4.8). Packages that contain `.vue` SFCs
  // (e.g. @bankai-vue/core) are checked by vue-tsc via their own `typecheck`
  // script, since tsgo can't parse SFCs — so they're excluded here.
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": ["packages/*/src/**/*.ts"],
  "exclude": ["**/*.vue", "packages/core/**", "**/dist/**", "**/node_modules/**"]
}

{
  "mcpServers": {
    "playwright-chromium": {
      "command": "pnpx",
      "args": ["@playwright/mcp@latest", "--browser=chromium"]
    },
    "playwright-firefox": {
      "command": "pnpx",
      "args": ["@playwright/mcp@latest", "--browser=firefox"]
    },
    "playwright-webkit": {
      "command": "pnpx",
      "args": ["@playwright/mcp@latest", "--browser=webkit"]
    }
  }
}

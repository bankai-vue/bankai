{
  "name": "@bankai-vue/monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "The agnostic, accessibility-first Vue 3 component framework.",
  "homepage": "https://github.com/bankai-vue/bankai",
  "license": "MIT",
  "author": "Christopher Quadflieg <chrissi92@hotmail.de> (https://github.com/Shinigami92)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bankai-vue/bankai.git"
  },
  "type": "module",
  "scripts": {
    "clean": "git clean -fdx --exclude .claude --exclude local",
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "dev": "pnpm --filter playground run dev",
    "docs:dev": "pnpm --filter @bankai-vue/docs run dev",
    "docs:generate": "pnpm --filter @bankai-vue/docs run generate",
    "docs:meta": "node scripts/generate-component-meta.ts",
    "docs:meta:check": "node scripts/generate-component-meta.ts --check",
    "docs:theming:check": "node scripts/check-theming-purposes.ts",
    "docs:prepare": "pnpm --filter @bankai-vue/docs exec nuxt prepare",
    "typecheck": "pnpm run typecheck:ts && pnpm run typecheck:vue && pnpm run typecheck:scripts",
    "typecheck:ts": "tsgo --noEmit -p tsconfig.json",
    "typecheck:vue": "pnpm --filter @bankai-vue/core --filter playground run typecheck",
    "typecheck:scripts": "tsgo --noEmit -p scripts/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "vitest --run --typecheck.only",
    "test:e2e": "playwright test",
    "test:update-visual-snapshots": "node scripts/update-visual-snapshots.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm run build && changeset publish",
    "preflight": "pnpm install && run-s format:check build docs:prepare lint typecheck docs:meta:check docs:theming:check test:types test"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@playwright/test": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "npm-run-all2": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "playwright": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vue-component-meta": "catalog:",
    "vue-tsc": "catalog:"
  },
  "engines": {
    "node": ">=24.11.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.17.0"
}

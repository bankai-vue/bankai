{
  "name": "@bankai-vue/monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "The agnostic, accessibility-first Vue 3 component framework.",
  "homepage": "https://github.com/bankai-vue/bankai",
  "license": "MIT",
  "author": "Christopher Quadflieg <chrissi92@hotmail.de> (https://github.com/Shinigami92)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bankai-vue/bankai.git"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "dev": "pnpm --filter playground run dev",
    "typecheck": "pnpm run typecheck:ts && pnpm run typecheck:vue",
    "typecheck:ts": "tsgo --noEmit -p tsconfig.json",
    "typecheck:vue": "pnpm -r --filter playground run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@playwright/test": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "playwright": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vue-tsc": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.9.0"
}

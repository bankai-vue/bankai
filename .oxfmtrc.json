{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    ".claude/**",
    "SPEC.md",
    "README.md",
    "CONTRIBUTING.md",
    "docs/app/utils/component-meta.generated.ts"
  ],
  "singleQuote": true,
  "sortImports": {
    "groups": [
      "type",
      ["builtin", "external", "internal"],
      { "newlinesBetween": false },
      ["parent", "sibling", "index"]
    ],
    "newlinesBetween": false
  },
  "overrides": [
    {
      "files": ["*.json5"],
      "options": {
        "quoteProps": "preserve",
        "singleQuote": false,
        "trailingComma": "none"
      }
    }
  ]
}

    },
    "./vue-router": {
      "types": "./dist/vue-router.d.ts",
      "import": "./dist/vue-router.js"
    },
    "./locales": {
      "types": "./dist/i18n/locales.d.ts",
      "import": "./dist/i18n/locales.js"
    },

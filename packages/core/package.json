{
  "name": "@bankai-vue/core",
  "version": "0.0.0",
  "description": "The agnostic, accessibility-first Vue 3 component framework — core components.",
  "homepage": "https://github.com/bankai-vue/bankai/tree/main/packages/core",
  "license": "MIT",
  "author": "Christopher Quadflieg <chrissi92@hotmail.de> (https://github.com/Shinigami92)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bankai-vue/bankai.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,

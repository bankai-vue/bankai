{
  // https://nuxt.com/docs/guide/concepts/typescript
  // Extends the config Nuxt generates under .nuxt/ — created by any `nuxi` run
  // (dev/build/generate/prepare). The shared root oxlint run DOES lint docs/, so it
  // must be prepared first (`pnpm docs:prepare`, wired into `preflight` and the CI lint
  // job) or type-aware oxlint fails to resolve this tsconfig. Full type-checking is still
  // owned by Nuxt's own `nuxi typecheck` (the CI `docs` job).
  "extends": "./.nuxt/tsconfig.json"
}
